# =========================================================
# Core
# =========================================================
TZ=Asia/Seoul
ADMIN_PASS=leejangwoo1!

# =========================================================
# DB (프로젝트 공용)
# =========================================================
DATABASE_URL=postgresql+psycopg2://postgres:leejangwoo1%21@100.105.75.47:5432/postgres
PG_WORK_MEM=256MB

# =========================================================
# Pool
# =========================================================
PG_POOL_SIZE=6
PG_MAX_OVERFLOW=6
PG_POOL_TIMEOUT=3
PG_POOL_RECYCLE=900
PG_POOL_LIFO=true

# =========================================================
# Network / connection
# =========================================================
PG_CONNECT_TIMEOUT=3
PG_TCP_KEEPALIVE=true
PG_KEEPALIVE_IDLE=30
PG_KEEPALIVE_INTERVAL=10
PG_KEEPALIVE_COUNT=5

# =========================================================
# Server-side query safety
# =========================================================
PG_STATEMENT_TIMEOUT_MS=12000
PG_LOCK_TIMEOUT_MS=2000
PG_IDLE_IN_TX_TIMEOUT_MS=15000

# =========================================================
# Streamlit refresh intervals
# =========================================================
ST_SYNC_SEC=8
ST_CHART_SEC=15
ST_NONOP_SEC=10
ST_NONOP_CHANGES_LIMIT=400

# =========================================================
# API timeouts (seconds)
# =========================================================
ST_SECTIONS_LATEST_TIMEOUT=6
ST_NONOP_WINDOW_TIMEOUT=6
ST_NONOP_CHANGES_TIMEOUT=4
ST_NONOP_UPDATE_TIMEOUT=8

# =========================================================
# Local host/port
# =========================================================
API_HOST=127.0.0.1
API_PORT=8000
UI_HOST=127.0.0.1
UI_PORT=8501

# =========================================================
# Base URLs
# =========================================================
API_BASE_URL=http://127.0.0.1:8000
SNAP_STREAMLIT_BASE_URL=http://127.0.0.1:8501

# =========================================================
# Snapshot Mailer
# =========================================================
SNAP_MODE=mail

# debug artifacts dir (png/html only)
SNAP_OUTPUT_DIR=C:/AptivAgent/snapshot

# Playwright capture stability
SNAP_TIMEOUT_MS=180000
SNAP_STABLE_MS=1500
SNAP_EPSILON_PX=8
SNAP_VIEWPORT_W=1920
SNAP_VIEWPORT_H=1080

# optional waits
SNAPSHOT_WAIT_SEC=0
SNAPSHOT_AFTER_READY_WAIT_SEC=0

# fallback only (READY 마커가 1순위라 오탐 위험 낮음)
SNAP_READY_BLOCK_TEXT=데이터조회중,Loading...,Please wait,로딩중,잠시만,조회중,불러오는중
SNAP_READY_MUST_HAVE_TEXT=

SNAP_DEBUG_SAVE_ARTIFACTS=1

# FastAPI email_list
SNAP_EMAIL_LIST_PATH=/email_list
SNAP_EMAIL_LIST_CONNECT_TIMEOUT_SEC=3
SNAP_EMAIL_LIST_READ_TIMEOUT_SEC=30
SNAP_EMAIL_LIST_RETRY=3

# exclude emails (필요 시만)
SNAP_EXCLUDE_EMAILS=

# PDF settings (요구사항: 가로 + 70% 배율)
SNAPSHOT_PDF_FORMAT=A4
SNAPSHOT_PDF_LANDSCAPE=1
SNAPSHOT_PDF_SCALE=0.70
SNAPSHOT_PDF_MARGIN_MM_PRINT=8

# overlay: 02 페이지에서 1번만 찍힘(코드로 제어)
SNAP_TS_OVERLAY_ENABLE=1
SNAP_TS_OVERLAY_FMT=%Y-%m-%d %H:%M:%S KST

# =========================================================
# SMTP (Gmail)
# =========================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=1
SMTP_USER=leejangwoo99@gmail.com
SMTP_PASS=yguhjcozrylyrmqv
SMTP_FROM=leejangwoo99@gmail.com

# =========================================================
# 운영 옵션: 중복실행/중복발송 방지
# =========================================================
SNAPSHOT_LOCK_FILE=C:/AptivAgent/_locks/snapshot_mailer.lock
SNAPSHOT_SENT_FILE=C:/AptivAgent/_state/snapshot_last_sent.txt
SNAP_SKIP_IF_ALREADY_SENT=1
SNAP_FORCE_SEND=0
SNAP_CONTINUE_ON_ERROR=1

# =========================================================
# 로그 파일 저장
# =========================================================
SNAPSHOT_LOG_DIR=C:/AptivAgent/logs

# =========================================================
# Snapshot Scheduler (운영형)
# =========================================================
SNAP_RUNNER_MODE=daemon
SNAP_SCHED_TIMES=08:29:59,20:29:59

# 폴링/트리거 윈도우
SNAP_SCHED_POLL_SEC=1
SNAP_SCHED_WINDOW_SEC=2

# 캐치업
SNAP_SCHED_CATCHUP=1
SNAP_SCHED_CATCHUP_LOOKBACK_MIN=240
SNAP_SCHED_CATCHUP_GRACE_SEC=5400

# 상태파일
SNAP_STATUS_FILE=C:/AptivAgent/_state/snapshot_status.json

# 선택
# SNAP_EVENT_LOG_URL=http://127.0.0.1:8000/snapshots/log